#!/bin/sh
# sandbox-tour: a self-contained, OFFLINE demonstration of the ICM runtime's
# enforcement and tamper-evidence layers, with zero credentials and no network.
#
# It builds a THROWAWAY run of this very skill in a disposable directory, pointing
# both $HOME and the working directory inside it, so nothing touches the user's real
# ~/.icm, project .icm/, or seal log. It then drives icm.sh through every mechanic
# that can be checked offline and prints the real command output as evidence.
#
# Demonstrated, in order:
#   1. stage scoping     - a stage's gate is silent until that stage is the active one
#   2. gate DENY         - the active gate denies its tool while the precondition is unmet
#   3. normalization     - the same gate matches an mcp__<server>__ wrapped tool name
#   4. non-gated tool    - a tool the gate does not name is unaffected
#   5. gate ALLOW        - satisfying the precondition lets the tool through
#   6. seal + verify     - anchor the evidence digests, verify them (SEAL OK)
#   7. seal tamper       - editing a SEALED file (events.jsonl) -> SEAL MISMATCH
#   8. manifest tamper   - editing a FROZEN contract (CONTEXT.md) -> gate DENY tampered
#
# No arguments. Env overrides: $ICM_SH (path to icm.sh), $ICM_DEMO_TMP (sandbox base).
# Exit 0 on a clean tour. The DENY and MISMATCH steps are EXPECTED outcomes and do
# NOT fail the script; a non-zero exit means the runtime itself misbehaved.
set -u

WS=cyril-antoni/icm-demo

# Locate icm.sh relative to this script. Logical (not -P) resolution on purpose,
# matching icm.sh's own SKILLS_DIR derivation, so a symlinked install resolves the
# same skills root rather than the source repo.
tool_dir=$(cd "$(dirname "$0")" && pwd)
skills_root=$(cd "$tool_dir/../../.." && pwd)
ICM="${ICM_SH:-$skills_root/icm/runtime/icm.sh}"
[ -f "$ICM" ] || { echo "sandbox-tour: cannot find icm.sh at $ICM (set ICM_SH)"; exit 2; }

# Build a disposable sandbox. HOME points inside it so the global skill-runs index
# and the seal log are disposable too; cwd points inside it so .icm/ is created there.
base="${ICM_DEMO_TMP:-${TMPDIR:-/tmp}}"
[ -n "$base" ] || base="/tmp"
sandbox=$(mktemp -d "$base/icm-demo.XXXXXX" 2>/dev/null) || { sandbox="$base/icm-demo.$$"; mkdir -p "$sandbox" 2>/dev/null || true; }
# Never rm -rf a relative or empty path; require an absolute, existing dir.
case "$sandbox" in /*) : ;; *) echo "sandbox-tour: refusing non-absolute sandbox '$sandbox'"; exit 2 ;; esac
[ -d "$sandbox" ] || { echo "sandbox-tour: could not create a sandbox under $base"; exit 2; }
trap 'cd /; [ -n "${sandbox:-}" ] && rm -rf "$sandbox"' EXIT INT TERM
export HOME="$sandbox"
cd "$sandbox" || { echo "sandbox-tour: cannot cd into sandbox $sandbox"; exit 2; }

say()  { printf '\n=== %s ===\n' "$1"; }
# Run one gate-check and label the outcome. gate-check is silent + exit 0 on ALLOW,
# and prints the DENY line + exit 1 on deny. Never aborts the script.
gate() { # $1 = label, $2 = tool name
    printf '\n--- %s ---\n$ icm.sh gate-check --tool %s\n' "$1" "$2"
    out=$("$ICM" gate-check --tool "$2" 2>&1); rc=$?
    if [ "$rc" -eq 0 ]; then
        printf 'ALLOW (gate-check exit 0)\n'
    elif [ "$rc" -eq 1 ]; then
        [ -n "$out" ] && printf '%s\n' "$out"
        printf 'DENIED (gate-check exit 1)\n'
    else
        [ -n "$out" ] && printf '%s\n' "$out"
        printf 'ERROR (gate-check exit %s - unexpected runtime fault, not a normal deny)\n' "$rc"
    fi
}

say "build a throwaway run of $WS (HOME and cwd both point inside the sandbox)"
printf '$ icm.sh init %s\n' "$WS"
# init prints the run dir on stdout and a gitignore note on stderr (icm.sh). Capture
# stdout so RUN is exactly the run just created - no ls, no guessing the newest dir.
RUN=$("$ICM" init "$WS" 2>/dev/null) || { echo "sandbox-tour: init failed"; exit 2; }
RUN=$(printf '%s\n' "$RUN" | grep -E '/[0-9]{4}-[0-9]{2}-[0-9]{2}_[0-9]{2}-[0-9]{2}-[0-9]{2}$' | head -1)
[ -n "$RUN" ] && [ -d "$RUN" ] || { echo "sandbox-tour: could not resolve run dir from init output"; exit 2; }
printf 'frozen run at: %s\n' "$RUN"

say "1. STAGE SCOPING: the stage-02 gate is silent while stage 01 is active"
gate "demo_publish while 01-lifecycle is active (expect ALLOW: 02 gate not active yet)" demo_publish

printf '\n$ icm.sh stage-done %s --stage 01-lifecycle   (advances the active stage to 02)\n' "$WS"
"$ICM" stage-done "$WS" --stage 01-lifecycle 2>&1

say "2. GATE DENY: 02-enforcement is now active and its precondition is unmet"
gate "demo_publish, output/ready.md absent (expect DENY: checker failed)" demo_publish

say "3. CROSS-HARNESS NORMALIZATION: the same gate matches an mcp__ wrapped name"
gate "mcp__claude_ai_Notion__demo_publish (expect DENY: wrapper stripped, gate matched)" mcp__claude_ai_Notion__demo_publish

say "4. NON-GATED TOOL: a tool the gate does not name is unaffected"
gate "Read (expect ALLOW: the gate names demo_publish, not Read)" Read

say "5. GATE ALLOW: satisfy the precondition, then the tool is let through"
printf '$ echo ready > %s/02-enforcement/output/ready.md\n' "$RUN"
mkdir -p "$RUN/02-enforcement/output"
printf 'ready\n' > "$RUN/02-enforcement/output/ready.md"
gate "demo_publish, output/ready.md present (expect ALLOW)" demo_publish

say "6. SEAL + VERIFY: anchor the evidence digests, then verify them"
printf '$ icm.sh seal %s\n' "$WS"
"$ICM" seal "$WS" 2>&1
printf '$ icm.sh verify-seal %s   (expect SEAL OK)\n' "$WS"
"$ICM" verify-seal "$WS" 2>&1 || true

say "7. SEAL TAMPER: editing a SEALED file is caught by verify-seal"
printf 'injecting a fabricated usage event into telemetry/events.jsonl ...\n'
printf '{"ts":"2026-01-01T00:00:00Z","type":"usage","tokens_out":999999}\n' >> "$RUN/telemetry/events.jsonl"
printf '$ icm.sh verify-seal %s   (expect SEAL MISMATCH, exit 1)\n' "$WS"
if "$ICM" verify-seal "$WS" 2>&1; then
    printf 'UNEXPECTED: verify-seal did not detect the edit\n'
else
    printf '(verify-seal exited 1, as expected)\n'
fi

say "8. MANIFEST TAMPER: editing a FROZEN contract is caught by gate-check"
printf 'appending a comment to %s/02-enforcement/CONTEXT.md ...\n' "$RUN"
printf '\n<!-- tampered -->\n' >> "$RUN/02-enforcement/CONTEXT.md"
gate "demo_publish after the contract edit (expect DENY: contract tampered)" demo_publish

say "tour complete - the sandbox $sandbox is now removed"
