#!/bin/sh
# gather-pr: deterministically gather a PR's summary, action feed, and link set.
#
# Usage: gather-pr <owner/repo> <pr-number> <out-dir>
# Writes:
#   <out-dir>/pr-context.md  - summary header, file buckets, chronological action feed
#   <out-dir>/links.tsv      - every URL found in PR free text, with source attribution
#   <out-dir>/pr.diff        - the change under review (sealed, reproducible)
#
# Pure and read-only (gh + jq). No model judgment: same PR state -> same output.
# Parses under bash 3.2 / POSIX sh.
set -eu

OR=${1:-}; PR=${2:-}; OUT=${3:-}
[ -n "$OR" ] && [ -n "$PR" ] && [ -n "$OUT" ] || { echo "usage: gather-pr <owner/repo> <pr#> <out-dir>" >&2; exit 2; }
command -v gh >/dev/null 2>&1 || { echo "gather-pr: gh not found" >&2; exit 3; }
command -v jq >/dev/null 2>&1 || { echo "gather-pr: jq not found" >&2; exit 3; }
mkdir -p "$OUT"

TMP=$(mktemp -d); trap 'rm -rf "$TMP"' EXIT
TAB=$(printf '\t')

gh pr view "$PR" --repo "$OR" --json \
  number,title,state,isDraft,author,createdAt,updatedAt,body,labels,files,additions,deletions,commits,reviews,comments,closingIssuesReferences,headRefOid \
  > "$TMP/pr.json" 2>"$TMP/err" || { echo "gather-pr: gh pr view failed:" >&2; cat "$TMP/err" >&2; exit 4; }

gh api --paginate "repos/$OR/issues/$PR/timeline" > "$TMP/timeline.json" 2>/dev/null || echo '[]' > "$TMP/timeline.json"

# ---- pr-context.md ----
{
  jq -r '
    "# PR Context: \(.title)", "",
    "- Repo: '"$OR"'  PR: #\(.number)  State: \(.state)\(if .isDraft then " (draft)" else "" end)",
    "- Author: \(.author.login // "?")  Created: \(.createdAt)  Updated: \(.updatedAt)",
    "- Size: \(.files | length) files, +\(.additions // 0) / -\(.deletions // 0)",
    "- Labels: \((.labels // []) | map(.name) | join(", ") // "none")",
    "- Linked issues: \((.closingIssuesReferences // []) | map("#\(.number) \(.title)") | join("; ") | if . == "" then "none" else . end)",
    ""' "$TMP/pr.json"

  echo "## File buckets"
  jq -r '.files[].path' "$TMP/pr.json" | while IFS= read -r f; do
      case "$f" in
        */__tests__/*|*.test.*|*.spec.*|test/*|tests/*|*/test/*|*/tests/*) b=test ;;
        *package-lock.json|*yarn.lock|*pnpm-lock.yaml|*Cargo.lock|*go.sum|*composer.lock|*Gemfile.lock) b=lockfile ;;
        */dist/*|*/build/*|*/generated/*|*.pb.go|*_pb2.py|*.gen.*|*.min.js) b=generated ;;
        *.md|docs/*|*/docs/*) b=docs ;;
        *.yml|*.yaml|*.json|*Dockerfile*|docker-compose*|*.env*|*.toml|*.ini|*.config.*) b=config ;;
        *) b=prod ;;
      esac
      printf '%s\t%s\n' "$b" "$f"
  done | sort | awk -F'\t' '
      { c[$1]++; files[$1]=files[$1] "  - " $2 "\n" }
      END {
        n=split("prod test config generated lockfile docs",o," ")
        printf "Buckets:"
        for(i=1;i<=n;i++) if(c[o[i]]>0) printf " %s=%d", o[i], c[o[i]]
        printf "\n\n"
        for(i=1;i<=n;i++) if(c[o[i]]>0) printf "### %s (%d)\n%s\n", o[i], c[o[i]], files[o[i]]
      }'

  echo "## Action feed (chronological)"
  jq -r '
    [ .[] | {
        ts: (.created_at // .submitted_at // .committer.date // ""),
        who: (.actor.login // .user.login // .author.login // .committer.name // "?"),
        ev: (.event // "comment"),
        note: ((.body // .message // "") | gsub("[\r\n]+";" ") | .[0:160])
      } ]
    | sort_by(.ts) | .[]
    | "- [\(.ts)] \(.who) \(.ev)\(if .note != "" then ": " + .note else "" end)"
  ' "$TMP/timeline.json" 2>/dev/null || echo "(timeline unavailable)"
} > "$OUT/pr-context.md"

# ---- links.tsv: every URL in free text, with source. Newlines collapsed so each
# source maps to one line before extraction. Columns: url <TAB> source ----
{
  jq -r '(.body // "") | gsub("[\r\n]+";" ") | "PR-body\t" + .' "$TMP/pr.json"
  jq -r '.comments[]? | "comment:\(.author.login // "?")\t" + ((.body // "") | gsub("[\r\n]+";" "))' "$TMP/pr.json"
  jq -r '.reviews[]?  | "review:\(.author.login // "?")\t" + ((.body // "") | gsub("[\r\n]+";" "))' "$TMP/pr.json"
  jq -r '.commits[]?  | "commit\t" + ((.messageBody // "") | gsub("[\r\n]+";" "))' "$TMP/pr.json"
} | while IFS="$TAB" read -r src text; do
    printf '%s\n' "$text" | grep -oE 'https?://[A-Za-z0-9._~:/?#@!$&'"'"'()*+,;=%-]+' 2>/dev/null \
      | sed 's/[).,]*$//' | while IFS= read -r u; do
          [ -n "$u" ] && printf '%s\t%s\n' "$u" "$src"
      done
done | sort -u > "$OUT/links.tsv"

# ---- checklist.tsv: the PR template's mandatory checklist as instantiated in the
# body, one row per box with its tick state. The tick is the AUTHOR's CLAIM, never
# evidence - stage 04 must audit every item to a uniform bar. Columns: state <TAB> item ----
jq -r '(.body // "")' "$TMP/pr.json" 2>/dev/null \
  | "$(dirname "$0")/extract-checklist" > "$OUT/checklist.tsv" 2>/dev/null || true
[ -f "$OUT/checklist.tsv" ] || : > "$OUT/checklist.tsv"

# ---- pr-template.md: the repo's PR template (ground truth for the mandatory
# checklist; a body can be edited to DROP items, so 04 compares body vs template).
# Best-effort over the common template locations; raw content, no base64 decode. ----
: > "$OUT/pr-template.md"
for p in \
  ".github/PULL_REQUEST_TEMPLATE.md" \
  ".github/pull_request_template.md" \
  "PULL_REQUEST_TEMPLATE.md" \
  "docs/PULL_REQUEST_TEMPLATE.md" \
  ".github/PULL_REQUEST_TEMPLATE/default.md"; do
    if gh api "repos/$OR/contents/$p" -H "Accept: application/vnd.github.raw" > "$TMP/tmpl" 2>/dev/null && [ -s "$TMP/tmpl" ]; then
      cp "$TMP/tmpl" "$OUT/pr-template.md"; break
    fi
done
[ -s "$OUT/pr-template.md" ] || echo "(no PR template found at common paths; the PR body checklist is the only source)" > "$OUT/pr-template.md"

# ---- prior-runs.tsv: sealed reviews of THIS SAME PR from earlier runs. Deterministic
# and cwd-trap-free: computed from OUT (= <runs-root>/<ts>/01-context/output), not a
# hand-run glob whose meaning depends on the caller's cwd. A non-empty list makes the
# current run a re-review (04 blind-pass + reconcile; 06 Independence disclosure). ----
: > "$OUT/prior-runs.tsv"
CUR_RUN=$(cd "$OUT/../.." 2>/dev/null && pwd || echo "")
RUNS_ROOT=$(cd "$OUT/../../.." 2>/dev/null && pwd || echo "")
if [ -n "$RUNS_ROOT" ] && [ -d "$RUNS_ROOT" ]; then
  for rev in "$RUNS_ROOT"/*/06-report/output/REVIEW-"$PR".md; do
    [ -f "$rev" ] || continue
    case "$rev" in "$CUR_RUN"/*) continue ;; esac
    printf '%s\n' "$rev" >> "$OUT/prior-runs.tsv"
  done
fi

# ---- seal.tsv: the reviewed-revision provenance. pr.diff is the PR head; if the local
# working tree (what a reviewer might Read/grep) is a different commit OR has uncommitted
# edits, on-disk reads are OUT-OF-SEAL. Deterministic: PR head SHA (gh) vs local HEAD SHA
# (git), plus a dirty-tree check so `diverged` catches uncommitted edits, not just SHAs. ----
PR_HEAD=$(jq -r '.headRefOid // ""' "$TMP/pr.json" 2>/dev/null || echo "")
LOCAL_HEAD=$(git rev-parse HEAD 2>/dev/null || echo "")
DIRTY=no
[ -n "$(git status --porcelain 2>/dev/null)" ] && DIRTY=yes
DIVERGED=no
[ -n "$PR_HEAD" ] && [ -n "$LOCAL_HEAD" ] && [ "$PR_HEAD" != "$LOCAL_HEAD" ] && DIVERGED=yes
[ "$DIRTY" = yes ] && DIVERGED=yes
{
  printf 'pr_head_sha\t%s\n' "$PR_HEAD"
  printf 'local_head_sha\t%s\n' "$LOCAL_HEAD"
  printf 'dirty\t%s\n' "$DIRTY"
  printf 'diverged\t%s\n' "$DIVERGED"
} > "$OUT/seal.tsv"

# ---- pr.diff: the change under review, sealed with the context. Fatal on failure -
# a review with no diff is worthless, so fail loud rather than degrade silently. ----
gh pr diff "$PR" --repo "$OR" > "$OUT/pr.diff" 2>"$TMP/differr" \
  || { echo "gather-pr: gh pr diff failed:" >&2; cat "$TMP/differr" >&2; exit 5; }

echo "gather-pr: $OUT/pr-context.md ($(wc -l < "$OUT/pr-context.md" | tr -d ' ') lines), $OUT/links.tsv ($(wc -l < "$OUT/links.tsv" | tr -d ' ') links), $OUT/checklist.tsv ($(wc -l < "$OUT/checklist.tsv" | tr -d ' ') items), $OUT/prior-runs.tsv ($(wc -l < "$OUT/prior-runs.tsv" | tr -d ' ') prior same-PR reviews), $OUT/seal.tsv (diverged=$(awk -F'\t' '$1=="diverged"{print $2}' "$OUT/seal.tsv")), $OUT/pr.diff ($(wc -l < "$OUT/pr.diff" | tr -d ' ') lines)"
