#!/bin/sh
# check-value-claims <findings.md> <pr.diff>
#
# Deterministic cross-check of the value gate's self-graded claims (#24618 hardening).
# The floor (introduced-by-diff, floor=pass) is model-written; the same model that wants
# to post a finding can label it floor=pass. This tool checks the one part of the claim
# an artifact can refute: a finding claiming introduced-by-diff=yes AND floor=pass (i.e.
# one that will post inline) must cite at least one file path the diff actually touches.
# It cannot catch semantic lies (a pre-existing pattern cited alongside a changed file
# still passes) - it catches the lazy ones (no cited file in the diff, no file cited).
#
# Parsing contract (mirrors stage 04): a finding BLOCK starts at a line whose first
# alphanumeric content is its id (`## F1 ...`, `**F2 ...`, `| F3 |`, `F4:`); an id
# mentioned mid-prose ("same root cause as F1") never starts or steals a block. The
# `Value:` line and any cited file paths attach to the current block. Conflicting
# Value lines in one block (pass AND fail, or yes AND no) are SUSPECT, not resolved.
# floor=pass with introduced-by-diff=no is SUSPECT: the floor's first conjunct IS
# introduced-by-diff, so that combination is a malformed (gate-bypassing) label.
#
# Diff paths come from ---/+++ headers AND `diff --git` / `rename from|to` / `Binary
# files` lines, so rename-only and binary-only PRs still produce a report.
#
# Emits TSV to stdout: F<n> <TAB> claim <TAB> verdict <TAB> detail
# verdict: consistent | exempt(introduced-by-diff=no) | exempt(floor=fail) | SUSPECT(<why>)
# Exit 0 on a produced report (stage 05 resolves SUSPECT rows: ground the claim in a
# changed file, or flip it to =no and demote); exit 2 on unusable input - including a
# diff with no parseable file paths, which is refused loudly rather than emitting an
# empty (and therefore SUSPECT-free) report.
set -eu

[ $# -eq 2 ] || { echo "usage: check-value-claims <findings.md> <pr.diff>" >&2; exit 2; }
findings=$1; diff=$2
[ -f "$findings" ] || { echo "check-value-claims: $findings not found" >&2; exit 2; }
[ -f "$diff" ] || { echo "check-value-claims: $diff not found" >&2; exit 2; }

dfiles=$(mktemp); trap 'rm -f "$dfiles"' EXIT
{
    sed -nE -e 's|^\+\+\+ b/||p' -e 's|^--- a/||p' "$diff"
    sed -nE 's|^diff --git a/(.*) b/.*|\1|p' "$diff"
    sed -nE 's|^diff --git a/.* b/(.*)|\1|p' "$diff"
    sed -nE -e 's|^rename from ||p' -e 's|^rename to ||p' "$diff"
    sed -nE 's|^Binary files a/(.*) and b/.* differ|\1|p' "$diff"
    sed -nE 's|^Binary files a/.* and b/(.*) differ|\1|p' "$diff"
} | grep -v '^/dev/null$' | sort -u > "$dfiles" || true
[ -s "$dfiles" ] \
    || { echo "check-value-claims: no file paths found in $diff (empty or malformed diff) - refusing to emit an empty report" >&2; exit 2; }

awk '
function ends(s, suf) { return length(s) >= length(suf) && substr(s, length(s) - length(suf) + 1) == suf }
NR == FNR { df[$0] = 1; next }
{
    # A block starts only where the id leads the line (after markup); prose mentions
    # of another F<n> must not steal attribution of the Value line or cited paths.
    if ($0 ~ /^[^[:alnum:]]*F[0-9]+/ && match($0, /F[0-9]+/)) {
        id = substr($0, RSTART, RLENGTH)
        if (!(id in seen)) { seen[id] = 1; order[++k] = id }
        cur = id
    }
    if (cur == "") next
    if ($0 ~ /Value:/) {
        c = ""; f = ""
        if ($0 ~ /introduced-by-diff=yes/) c = "yes"
        else if ($0 ~ /introduced-by-diff=no/) c = "no"
        if ($0 ~ /floor=pass/) f = "pass"
        else if ($0 ~ /floor=fail/) f = "fail"
        # Conflicting re-labels in one block are flagged, never silently resolved.
        if (c != "") { if ((cur in claim) && claim[cur] != c) conflict[cur] = 1; claim[cur] = c }
        if (f != "") { if ((cur in floor) && floor[cur] != f) conflict[cur] = 1; floor[cur] = f }
    }
    rest = $0
    # Path shapes: dir/file (extension optional, [bracketed] Next.js-style segments
    # and @scoped segments allowed) or a bare file with an extension.
    while (match(rest, /(([][@A-Za-z0-9_.-]+\/)+[][@A-Za-z0-9_.-]+|[A-Za-z0-9_-]+\.[A-Za-z0-9]+)/)) {
        paths[cur] = paths[cur] " " substr(rest, RSTART, RLENGTH)
        rest = substr(rest, RSTART + RLENGTH)
    }
}
END {
    for (i = 1; i <= k; i++) {
        id = order[i]
        c = (id in claim) ? claim[id] : "missing"
        f = (id in floor) ? floor[id] : "missing"
        if (id in conflict) { printf "%s\t%s\tSUSPECT(conflicting Value lines in one block)\t-\n", id, c; continue }
        if (c == "missing" || f == "missing") { printf "%s\t%s\tSUSPECT(no Value line)\t-\n", id, c; continue }
        # floor=pass REQUIRES introduced-by-diff=yes (the floor is a conjunction);
        # =no + pass is a malformed label that would otherwise dodge the grounding
        # requirement below via the =no exemption.
        if (c == "no" && f == "pass") { printf "%s\tintroduced-by-diff=no\tSUSPECT(floor=pass requires introduced-by-diff=yes)\t-\n", id; continue }
        if (c == "no")     { printf "%s\tintroduced-by-diff=no\texempt(introduced-by-diff=no)\t-\n", id; continue }
        if (f == "fail")   { printf "%s\tintroduced-by-diff=yes\texempt(floor=fail)\t-\n", id; continue }
        n = split(substr(paths[id], 2), arr, " ")
        hit = ""
        for (j = 1; j <= n && hit == ""; j++) {
            p = arr[j]; sub(/:[0-9].*$/, "", p); sub(/[.,;:]+$/, "", p)
            for (d in df) {
                # Equality; diff path ending in the cited suffix; or the cited path
                # ending in the diff path ONLY when the diff path itself is nested -
                # a root-level diff file (no "/") must not ground any deeper cited
                # path that merely shares its basename.
                if (d == p || ends(d, "/" p) || (index(d, "/") && ends(p, "/" d))) { hit = p; break }
            }
        }
        if (hit != "")      printf "%s\tintroduced-by-diff=yes\tconsistent\t%s\n", id, hit
        else if (n == 0)    printf "%s\tintroduced-by-diff=yes\tSUSPECT(no file path cited in the finding block)\t-\n", id
        else                printf "%s\tintroduced-by-diff=yes\tSUSPECT(no cited file is touched by the diff)\t%s\n", id, arr[1]
    }
}
' "$dfiles" "$findings"
