#!/bin/sh
# close-run: deterministically close the CURRENT run of kakkoidev/icm-demo -
# recompute telemetry, audit, seal, verify - and index the evidence produced by
# stages 01 and 02, so the pipeline's data flow is visible. Reports on the REAL run
# in the project cwd; the model adds one sentence of framing.
#
# Like run-report, this pushes the bash-reachable work (the four closing commands and
# the evidence index) into a tool, so the receipt is reproducible and eval-checkable.
# No arguments. Honors $ICM_SH; resolves icm.sh relative to this script otherwise.
set -u
WS=kakkoidev/icm-demo

tool_dir=$(cd "$(dirname "$0")" && pwd)
skills_root=$(cd "$tool_dir/../../.." && pwd)
ICM="${ICM_SH:-$skills_root/icm/runtime/icm.sh}"
[ -f "$ICM" ] || { echo "close-run: cannot find icm.sh at $ICM (set ICM_SH)"; exit 2; }

[ -d ".icm/$WS" ] || { echo "close-run: no run for $WS in $PWD - run 'icm.sh init $WS' first"; exit 2; }
RUN=""
for d in ".icm/$WS"/*/; do [ -d "$d" ] && RUN=${d%/}; done
[ -n "$RUN" ] || { echo "close-run: no run dir under .icm/$WS"; exit 2; }

say() { printf '\n=== %s ===\n' "$1"; }

say "REIFY TELEMETRY (icm.sh reify-telemetry)"
printf '$ icm.sh reify-telemetry %s\n' "$WS"; "$ICM" reify-telemetry "$WS" 2>&1 || true

say "AUDIT (icm.sh audit)"
printf '$ icm.sh audit %s\n' "$WS"
audit=$("$ICM" audit "$WS" 2>&1)
printf '%s\n' "$audit"
if printf '%s\n' "$audit" | grep -q 'ADVISORY ONLY'; then
    say "NOTE on the one audit deviation"
    printf 'EXPECTED when the enforcement hook is not installed: audit reports "gates\n'
    printf 'were ADVISORY ONLY" and counts one deviation. That is the runtime honestly\n'
    printf 'reporting your setup, not a skill failure - enforcement was still PROVEN in\n'
    printf 'stage 02 (gate-check DENY then ALLOW against real frozen artifacts). Run\n'
    printf 'installer.sh --hooks and re-run for a zero-deviation audit.\n'
fi

say "SEAL + VERIFY (icm.sh seal / verify-seal)"
printf '$ icm.sh seal %s\n' "$WS"; "$ICM" seal "$WS" 2>&1 || true
printf '$ icm.sh verify-seal %s\n' "$WS"
vs=$("$ICM" verify-seal "$WS" 2>&1); vrc=$?
printf '%s\n' "$vs"
[ "$vrc" -eq 0 ] || printf '(verify-seal exit %s - unexpected; investigate before trusting the seal)\n' "$vrc"

say "EVIDENCE INDEX (this run's full pipeline)"
for ev in 01-lifecycle/output/lifecycle.md 02-enforcement/output/enforcement.md 03-telemetry-seal/output/telemetry.md; do
    p="$RUN/$ev"
    if [ -s "$p" ]; then
        printf '  [present] %s (%s lines)\n' "$p" "$(wc -l < "$p" | tr -d ' ')"
    else
        printf '  [missing] %s\n' "$p"
    fi
done

say "close-run complete - commit .icm-seals.log to anchor this run's evidence"
