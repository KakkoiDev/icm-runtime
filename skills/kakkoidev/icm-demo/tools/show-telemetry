#!/bin/sh
# show-telemetry: stage 03's body. Recompute exact per-stage counts (reify) and show
# this run's telemetry EVENTS - each stage_done/reify event carries the four token
# fields (tokens_in / cache_creation / cache_read / tokens_out) kept separate, so cost
# is computable and cache reads never inflate input. Reports on the real run in cwd.
#
# It reads the events directly (not via `audit`) so it works regardless of run
# completeness, and it does NOT audit or seal: those are POST-RUN finalization
# (tools/close-run), run AFTER this stage is closed - a stage cannot audit or seal
# itself. The full per-stage token TABLE shows in close-run's audit (a complete run).
# No arguments. Honors $ICM_SH; resolves icm.sh relative to this script otherwise.
set -u
WS=kakkoidev/icm-demo

tool_dir=$(cd "$(dirname "$0")" && pwd)
skills_root=$(cd "$tool_dir/../../.." && pwd)
ICM="${ICM_SH:-$skills_root/icm/runtime/icm.sh}"
[ -f "$ICM" ] || { echo "show-telemetry: cannot find icm.sh at $ICM (set ICM_SH)"; exit 2; }
[ -d ".icm/$WS" ] || { echo "show-telemetry: no run for $WS in $PWD - run 'icm.sh init $WS' first"; exit 2; }
RUN=""
for d in ".icm/$WS"/*/; do [ -d "$d" ] && RUN=${d%/}; done
[ -n "$RUN" ] || { echo "show-telemetry: no run dir under .icm/$WS"; exit 2; }

say() { printf '\n=== %s ===\n' "$1"; }

say "REIFY TELEMETRY (icm.sh reify-telemetry)"
printf '$ icm.sh reify-telemetry %s\n' "$WS"
"$ICM" reify-telemetry "$WS" 2>&1 || true

say "PER-STAGE TELEMETRY EVENTS (four token fields, kept separate)"
printf 'Each stage_done/reify event in events.jsonl carries tokens_in (new input),\n'
printf 'cache_creation, cache_read and tokens_out separately, so cost is computable and\n'
printf 'cache reads never inflate input. This run'"'"'s telemetry events so far:\n\n'
grep -E '"type":"(stage_done|reify)"' "$RUN/telemetry/events.jsonl" 2>/dev/null || printf '(no stage_done events yet)\n'
printf '\n(null counts appear only when there is no live transcript - e.g. the stage 02\n'
printf 'sandbox; a real /icm-demo run records real numbers here. The full per-stage\n'
printf 'token TABLE prints in the post-run audit, when the run is complete.)\n'

say "show-telemetry complete - the run is closed and sealed in the post-run step (close-run)"
